{
  "expo": {
    "name": "alter-ceo",
    "slug": "alter-ceo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alterceo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ramonamaro.alter-ceo",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Necesitamos acceso al micrófono para grabar tus respuestas de audio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "package": "com.ramonamaro.alterceo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/with-async-storage-maven",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir biometría para iniciar sesión de forma segura."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Necesitamos acceso al micrófono para grabar tus respuestas de audio."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "75fe4230-fac6-489c-a74e-ab20340aba52"
      }
    }
  }
}
