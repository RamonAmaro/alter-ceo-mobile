{
  "expo": {
    "name": "AlterCEO",
    "slug": "AlterCEO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "alterceo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.ramonamaro.AlterCEO",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Necesitamos acceso al micrófono para grabar tus respuestas de audio."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.ramonamaro.AlterCEO"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permitir biometría para iniciar sesión de forma segura."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Necesitamos acceso al micrófono para grabar tus respuestas de audio."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
